PROJECT_BRIEF          = "Multi-platform modular bootloader"
PROJECT_NUMBER         = 0.3.0
OUTPUT_DIRECTORY       = docs/api
INPUT                  = include/ core/ hal/ stage0/ stage1/ boards/
FILE_PATTERNS          = *.h *.c
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_STATIC         = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES
SORT_MEMBER_DOCS       = NO
SHOW_INCLUDE_FILES     = YES
JAVADOC_AUTOBRIEF      = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
